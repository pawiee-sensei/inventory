<%- include('../layouts/adminLayout', {
title: 'Product Inventory',
body: `

<div class="page-header">
  <h1>Product Inventory</h1>
  <button id="openProductModal" class="add-btn">+ Add Product</button>
</div>

<!-- ================= ADD PRODUCT MODAL ================= -->
<div id="productModal" class="modal hidden">
  <div class="modal-content">
    <div class="modal-header">
      <h2>Add Product</h2>
      <button type="button" id="closeProductModal" class="close-btn">&times;</button>
    </div>

    <form id="productForm" enctype="multipart/form-data" class="modal-form">

      <div class="form-group">
        <label>Product Name</label>
        <input name="name" required>
      </div>

      <div class="form-group">
        <label>Description</label>
        <textarea name="description"></textarea>
      </div>

      <div class="form-group">
        <label>Category</label>
        <select name="category">
          <option value="Meal">Meal</option>
          <option value="Drink">Drink</option>
          <option value="Frozen">Frozen</option>
          <option value="Supplies">Supplies</option>
        </select>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Cost Price</label>
          <input name="cost_price" type="number" step="0.01">
        </div>

        <div class="form-group">
          <label>Selling Price</label>
          <input name="selling_price" type="number" step="0.01">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Initial Stock</label>
          <input name="current_stock" type="number" value="0">
        </div>

        <div class="form-group">
          <label>Unit</label>
          <input name="unit">
        </div>
      </div>

      <div class="form-group">
        <label>Product Image</label>
        <input type="file" name="image">
      </div>

      <button type="submit" class="primary-btn">Create Product</button>
    </form>
  </div>
</div>

<!-- ================= EDIT PRODUCT MODAL ================= -->
<div id="editModal" class="modal hidden">
  <div class="modal-content">
    <div class="modal-header">
      <h2>Edit Product</h2>
      <button type="button" id="closeEditModal" class="close-btn">&times;</button>
    </div>

    <form id="editForm" enctype="multipart/form-data" class="modal-form">
      <input type="hidden" id="edit_id" name="id">

      <div class="form-group">
        <label>Product Name</label>
        <input id="edit_name" name="name" required>
      </div>

      <div class="form-group">
        <label>Description</label>
        <textarea id="edit_description" name="description"></textarea>
      </div>

      <div class="form-group">
        <label>Category</label>
        <select id="edit_category" name="category">
          <option value="Meal">Meal</option>
          <option value="Drink">Drink</option>
          <option value="Frozen">Frozen</option>
          <option value="Supplies">Supplies</option>
        </select>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Cost Price</label>
          <input id="edit_cost" name="cost_price" type="number" step="0.01">
        </div>

        <div class="form-group">
          <label>Selling Price</label>
          <input id="edit_price" name="selling_price" type="number" step="0.01">
        </div>
      </div>

      <div class="form-group">
        <label>Replace Image</label>
        <input type="file" name="image">
      </div>

      <button type="submit" class="primary-btn">Update Product</button>
    </form>
  </div>
</div>

<!-- ================= PRODUCT TABLE ================= -->
<div class="table-container">
  <table id="productTable">
    <thead>
      <tr>
        <th>Image</th>
        <th>Product</th>
        <th>Category</th>
        <th>Stock</th>
        <th>Price</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody id="productBody"></tbody>
  </table>
</div>

`
}) %>
