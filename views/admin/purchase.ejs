<%- include('../layouts/adminLayout', {
title: 'Purchase Orders',
body: `

<link rel="stylesheet" href="/css/admin-purchase.css">

<div class="page-header">
  <h1>Purchase Orders</h1>
  <div>
    <button id="openSupplierModal" class="secondary-btn">Supplier</button>
    <button id="openPOModal" class="primary-btn">Create PO</button>
  </div>
</div>

<div class="table-wrapper">
  <table id="poTable">
    <thead>
      <tr>
        <th>ID</th>
        <th>Supplier</th>
        <th>Items</th>
        <th>Qty</th>
        <th>Status</th>
        <th>Total Cost</th>
        <th>Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody id="poBody"></tbody>
  </table>
</div>

<!-- ================= SUPPLIER MODAL ================= -->
<div id="supplierModal" class="modal hidden">
  <div class="modal-content">
    <div class="modal-header">
      <h2>Add Supplier</h2>
      <button id="closeSupplierModal" class="close-btn">&times;</button>
    </div>

    <form id="supplierForm">
      <input name="name" placeholder="Supplier Name" required>
      <input name="contact_person" placeholder="Contact Person">
      <input name="phone" placeholder="Phone">
      <input name="email" placeholder="Email">
      <textarea name="address" placeholder="Address"></textarea>
      <button type="submit" class="primary-btn">Save Supplier</button>
    </form>
  </div>
</div>

<!-- ================= CREATE PO MODAL ================= -->
<div id="poModal" class="modal hidden">
  <div class="modal-content">
    <div class="modal-header">
      <h2>Create Purchase Order</h2>
      <button id="closePOModal" class="close-btn">&times;</button>
    </div>

    <form id="poForm">
      <label>Supplier</label>
      <select name="supplier_id" id="supplierSelect"></select>
      <button type="submit" class="primary-btn">Create PO</button>
    </form>
  </div>
</div>

<!-- ================= PO DETAILS MODAL ================= -->
<div id="itemsModal" class="modal hidden">
  <div class="modal-content large">

    <div class="modal-header">
      <h2>Purchase Order Details</h2>
      <button id="closeItemsModal" class="close-btn">&times;</button>
    </div>

    <!-- HEADER -->
   <div class="po-header">

    <div class="po-col supplier-col">
      <span class="po-label">Supplier</span>
      <h3 id="poSupplier"></h3>
    </div>

    <div class="po-col date-col">
      
      <div id="poDate"></div>
    </div>

    <div class="po-col status-col">
      <div id="poStatus"></div>
    </div>

  </div>

<hr class="po-divider">

    <!-- ADD ITEM FORM -->
    <form id="itemForm" class="po-form">
      <input type="hidden" id="po_id">
      <div class="form-row">
        <select id="productSelect"></select>
        <input id="qtyInput" type="number" placeholder="Qty">
        <input id="costInput" type="number" step="0.01" placeholder="Cost">
        <button type="submit" class="primary-btn">Add</button>
      </div>
    </form>

    <!-- ITEMS TABLE -->
    <div class="po-items-table">
      <table>
        <thead>
          <tr>
            <th>Product</th>
            <th>Qty</th>
            <th>Cost</th>
            <th>Subtotal</th>
          </tr>
        </thead>
        <tbody id="poItemsList"></tbody>
      </table>
    </div>

    <!-- TOTAL SECTION -->
    <div id="poTotalSection" class="po-total-section hidden">
      <div class="po-total-line">
        <span>Total</span>
        <strong>₱<span id="poTotal"></span></strong>
      </div>
    </div>

  </div>
</div>

<script src="/js/adminPurchase.js"></script>

`
}) %>