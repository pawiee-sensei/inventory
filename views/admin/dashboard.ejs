<%- include('../layouts/adminLayout', {
title: 'Admin Dashboard',
body: `

<div class="page-header">
  <div>
    <h1 class="page-title">Inventory Overview</h1>
    <p class="page-subtitle">Real-time snapshot of your stock health</p>
  </div>
</div>

<div class="metrics-grid">

  <div class="metric">
    <span class="metric-label">TOTAL PRODUCTS</span>
    <span id="m_total" class="metric-value">0</span>
  </div>

  <div class="metric">
    <span class="metric-label">LOW STOCK</span>
    <span id="m_low" class="metric-value warning">0</span>
  </div>

  <div class="metric">
    <span class="metric-label">OUT OF STOCK</span>
    <span id="m_out" class="metric-value danger">0</span>
  </div>

  <div class="metric">
    <span class="metric-label">HEALTHY ITEMS</span>
    <span id="m_healthy" class="metric-value success">0</span>
  </div>

  <div class="metric">
    <span class="metric-label">INVENTORY VALUE</span>
    <span id="m_value" class="metric-value primary">₱0</span>
  </div>

</div>

<script src="/js/adminDashboard.js"></script>

`
}) %>